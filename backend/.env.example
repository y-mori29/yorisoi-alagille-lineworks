PORT=8082
DEMO_MODE=1

# Google Cloud
GOOGLE_CLOUD_PROJECT=yorisoi-dev-477515
FIRESTORE_DATABASE_ID=yorisoi-alagille
GCS_BUCKET=yorisoi-dev-477515-yorisoi-alagille-files
GOOGLE_GENAI_API_KEY=
LAB_OCR_MODE=sample
# 公開デモで実OCRを使う環境だけ gemini に変更し、キーはSecret Managerから渡す。
OCR_PER_ACCOUNT_LIMIT=8
OCR_DAILY_LIMIT=100
OCR_CONCURRENCY_LIMIT=2
AUTH_REQUIRED=0
ALAGILLE_API_MODE=1
GEMINI_OCR_MODEL=gemini-3.1-flash-lite
GEMINI_OCR_FALLBACK_MODEL=gemini-3.5-flash

# Single-tenant default for this disease-specific app
DEFAULT_TENANT_ID=alagille-family

# LINE WORKS settings
LINE_WORKS_CLIENT_ID=
LINE_WORKS_CLIENT_SECRET=
LINE_WORKS_BOT_ID=
LINE_WORKS_SERVICE_ACCOUNT=
LINE_WORKS_PRIVATE_KEY_PATH=secure/lineworks-private-key.pem
LINE_WORKS_CALLBACK_SECRET=

# Optional LINE compatibility fields kept while the copied patient UI is being separated
LIFF_ID=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
